---
const { Content } = await import("../../content/about.md");
---

<div class="about-prose pb-24">
  <Content />
</div>

<style>
  .about-prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .about-prose :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .about-prose :global(p) {
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .about-prose :global(ul) {
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    list-style-type: disc;
  }

  .about-prose :global(ol) {
    color: var(--color-text-secondary);
    line-height: 1.75;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    list-style-type: decimal;
  }

  .about-prose :global(li) {
    margin-bottom: 0.25rem;
  }

  .about-prose :global(li)::marker {
    color: var(--color-text-secondary);
  }

  .about-prose :global(a) {
    color: var(--color-accent-blue);
    text-decoration: underline;
  }

  .about-prose :global(strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  @media (min-width: 768px) {
    .about-prose :global(h2) {
      font-size: 1.875rem;
    }

    .about-prose :global(h3) {
      font-size: 1.5rem;
    }

    .about-prose :global(p),
    .about-prose :global(ul),
    .about-prose :global(ol) {
      font-size: 1.25rem;
    }
  }
</style>

<script>
  const el = document.querySelector('.dynamic-age');
  if (el) {
    const birth = new Date(1997, 6, 27);
    const today = new Date();
    let age = today.getFullYear() - birth.getFullYear();
    const monthDiff = today.getMonth() - birth.getMonth();
    if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birth.getDate())) {
      age--;
    }
    el.textContent = String(age);
  }
</script>
