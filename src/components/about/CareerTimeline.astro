---
import { careerItems } from "../../data/career";
---

<div class="flex flex-col items-center px-4 pb-24">
  <div class="max-w-2xl mx-auto w-full">

    <div class="relative">
      <!-- timeline line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-accent-blue/20"></div>

      {careerItems.map((item, i) => (
        <div
          class={`relative flex items-start mb-10 ${
            i % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"
          }`}
        >
          {/* dot */}
          <div class="absolute left-4 md:left-1/2 w-3 h-3 -translate-x-1/2 rounded-full bg-accent-blue/40 border-2 border-white shadow-sm mt-1.5" />

          {/* content */}
          <div
            class={`ml-10 md:ml-0 md:w-[45%] ${
              i % 2 === 0 ? "md:pr-8 md:text-right" : "md:pl-8"
            }`}
          >
            <span class="text-xs text-text-muted font-mono">{item.period}</span>
            <h3 class="text-base font-semibold text-text-primary mt-1">
              {item.title}
            </h3>
            <p class="text-sm text-text-secondary">{item.role}</p>
            {item.description && (
              <p class="text-sm text-text-muted mt-1">{item.description}</p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
