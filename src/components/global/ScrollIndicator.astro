---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div class="flex flex-col items-center py-12">
  <span class="text-sm text-text-muted font-medium">{label}</span>
  <div class="mt-2 bounce-arrow">
    <svg
      class="w-5 h-5 mx-auto text-text-muted"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7"
      />
    </svg>
  </div>
</div>
