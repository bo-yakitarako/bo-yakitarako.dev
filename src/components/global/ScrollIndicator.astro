---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div class="scroll-indicator flex flex-col items-center py-12 opacity-0 transition-opacity duration-500" data-indicator>
  <span class="text-sm text-text-muted font-medium">{label}</span>
  <div class="mt-2 bounce-arrow">
    <svg
      class="w-5 h-5 mx-auto text-text-muted"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7"
      />
    </svg>
  </div>
</div>

<script>
  function initIndicators() {
    const indicators = document.querySelectorAll<HTMLElement>("[data-indicator]");
    if (!indicators.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const el = entry.target as HTMLElement;
          el.style.opacity = entry.isIntersecting ? "1" : "0";
        }
      },
      { threshold: 0.5 }
    );

    for (const el of indicators) {
      observer.observe(el);
    }
  }

  initIndicators();
  document.addEventListener("astro:page-load", initIndicators);
</script>
