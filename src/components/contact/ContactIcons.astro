---
const contacts = [
  {
    label: "GitHub",
    href: "https://github.com/bo-yakitarako",
    icon: `<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" fill="currentColor"/>`,
  },
  {
    label: "X",
    href: "https://x.com/bo_yakitarako",
    icon: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="currentColor"/>`,
  },
  {
    label: "Email",
    href: "mailto:contact@bo-yakitarako.dev",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" stroke="currentColor" fill="none"/>`,
  },
];
---

<div class="flex flex-col items-center px-4 pb-4">

  <div class="flex items-center gap-8 md:gap-12">
    {contacts.map((c, i) => (
      <a
        href={c.href}
        target={c.href.startsWith("mailto:") ? undefined : "_blank"}
        rel={c.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
        class="group flex flex-col items-center gap-3"
        aria-label={c.label}
      >
        <div
          class="w-16 h-16 md:w-28 md:h-28 rounded-full
                 bg-white/30 backdrop-blur-sm
                 border border-white/40
                 shadow-[0_4px_16px_rgba(74,158,255,0.1)]
                 flex items-center justify-center
                 group-hover:bg-white/50 group-hover:scale-110
                 transition-all duration-300
                 bubble-float"
          style={`animation-duration: ${4 + i * 0.7}s; animation-delay: ${i * 0.5}s;`}
        >
          <svg
            class="w-7 h-7 md:w-11 md:h-11 text-text-secondary group-hover:text-accent-blue transition-colors"
            viewBox="0 0 24 24"
            set:html={c.icon}
          />
        </div>
        <span class="text-xs md:text-base text-text-muted group-hover:text-text-secondary transition-colors">
          {c.label}
        </span>
      </a>
    ))}
  </div>
</div>
