---
import BubbleCanvas from "../bubble/BubbleCanvas.tsx";
import Header from "../global/Header.tsx";
import ScrollRouter from "./ScrollRouter.tsx";
import LandingHero from "../landing/LandingHero.tsx";
import AboutIntro from "../about/AboutIntro.astro";
import CareerTimeline from "../about/CareerTimeline.astro";
import TechBubbles from "../bubble/TechBubbles.tsx";
import WorksBubbleGrid from "../works/WorksBubbleGrid.tsx";
import ContactIcons from "../contact/ContactIcons.astro";
import ScrollIndicator from "../global/ScrollIndicator.tsx";
import StickyTitle from "../global/StickyTitle.tsx";
import { techItems } from "../../data/tech";
import { workItems } from "../../data/works";

interface Props {
  initialSection?: string;
}

const { initialSection = "section-top" } = Astro.props;
---

<BubbleCanvas client:load />
<Header client:load />
<ScrollRouter client:load />

<section id="section-top" data-route="/">
  <LandingHero client:load />
</section>

<section id="section-about" data-route="/about" class="min-h-[130vh] pt-[25vh] scroll-mt-14">
  <StickyTitle sectionId="section-about" title="About" icon="/images/avatar.svg" client:load />
  <AboutIntro />
  <ScrollIndicator sectionId="section-about" label="career" client:load />
</section>

<section id="section-career" data-route="/career" class="min-h-[130vh] pt-[25vh] scroll-mt-14">
  <StickyTitle sectionId="section-career" title="Career" client:load />
  <CareerTimeline />
  <ScrollIndicator sectionId="section-career" label="tech" client:load />
</section>

<section id="section-tech" data-route="/tech" class="min-h-[130vh] pt-[25vh] scroll-mt-14">
  <StickyTitle sectionId="section-tech" title="Tech Stack" client:load />
  <TechBubbles items={techItems} client:visible />
  <ScrollIndicator sectionId="section-tech" label="works" client:load />
</section>

<section id="section-works" data-route="/works" class="min-h-[130vh] pt-[25vh] scroll-mt-14">
  <StickyTitle sectionId="section-works" title="Works" client:load />
  <WorksBubbleGrid items={workItems} client:visible />
  <ScrollIndicator sectionId="section-works" label="contact" client:load />
</section>

<section id="section-contact" data-route="/contact" class="min-h-screen flex flex-col items-center justify-center scroll-mt-14">
  <h2 class="text-2xl md:text-3xl font-bold text-text-primary text-center pb-8">Contact</h2>
  <ContactIcons />
</section>

{initialSection !== "section-top" && (
  <script is:inline define:vars={{ initialSection }}>
    if (history.scrollRestoration) {
      history.scrollRestoration = "manual";
    }
    function scrollToSection() {
      const el = document.getElementById(initialSection);
      if (el) {
        const top = el.getBoundingClientRect().top + window.scrollY;
        window.scrollTo({ top: top + window.innerHeight * 0.25, behavior: "instant" });
      }
    }
    scrollToSection();
    requestAnimationFrame(scrollToSection);
  </script>
)}
